# Environment Variables for LegalDocsKE

# M-Pesa Daraja API Configuration
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=your_shortcode
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://legaldocske.vercel.app
MPESA_ENVIRONMENT=sandbox

# Neon (Serverless Postgres)
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxx
EMAIL_FROM=LegalDocsKE <noreply@legaldocske.vercel.app>

# Admin
ADMIN_SECRET=set-a-strong-random-password-here

# App
NEXT_PUBLIC_APP_URL=https://legaldocske.vercel.app
